   "source": [
    "START\n",
    "  Set Total = 0\n",
    "  WHILE there are more items:\n",
    "    Scan item\n",
    "    Add item price to Total\n",
    "  END WHILE\n",
    "  \n",
    "  Get Payment from customer\n",
    "  IF Payment is successful:\n",
    "    Print Receipt\n",
    "    Give items to customer\n",
    "  ELSE:\n",
    "    Ask for another payment method\n",
    "  END IF\n",
    "STOP\n",
    "\n",
