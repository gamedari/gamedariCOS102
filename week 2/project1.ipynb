   "metadata": {},
   "source": [
    "START\n",
    "  INPUT Name1, Age1\n",
    "  INPUT Name2, Age2\n",
    "\n",
    "  PRINT \"Original\"x\n",
    "  PRINT Name1, \" is \", Age1\n",
    "  PRINT Name2, \" is \", Age2\n",
    "\n",
    "  Set Temp = Age1    \n",
    "  Set Age1 = Age2    \n",
    "  Set Age2 = Temp    \n",
    "\n",
    "  PRINT \"After swapping:\"\n",
    "  PRINT Name1, \" is now \", Age1\n",
    "  PRINT Name2, \" is now \", Age2\n",
    "STOP"
   ]
  }
